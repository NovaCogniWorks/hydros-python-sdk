# Shared MQTT broker configuration for custom-agent/pump.
#
# Copy this file to custom-agent/pump/env.properties for local or deployment
# runs. Do not commit the real env.properties file.

mqtt_broker_url=tcp://127.0.0.1
mqtt_broker_port=1883

# Optional. If omitted, the SDK derives mqtt_topic from hydros_cluster_id.
# mqtt_topic=/hydros/commands/coordination/pump-dev

# Optional MQTT authentication.
# mqtt_username=
# mqtt_password=

hydros_cluster_id=pump-dev
hydros_node_id=local
metrics_topic=/hydros/data/edges/{hydros_cluster_id}
